# S3-compatible storage (e.g., Hetzner Object Storage)
KK_S3_SERVICE_URL=https://fsn1.your-objectstorage.com
KK_S3_BUCKET_NAME=knockknock-cvs
KK_S3_ACCESS_KEY=
KK_S3_SECRET_KEY=

# SMTP
KK_EMAIL_SMTP_HOST=smtp.example.com
KK_EMAIL_SMTP_PORT=587
KK_EMAIL_FROM_ADDRESS=noreply@getknocknock.de
KK_EMAIL_FROM_NAME=Knock Knock
