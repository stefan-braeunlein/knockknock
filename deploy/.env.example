# ── SensorHub ──────────────────────────────────────────────
DB_PASSWORD=changeme
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_DB_PASSWORD=changeme
VITE_MAPBOX_TOKEN=
CORS_ORIGINS=https://sensorhub.digital
ASPNETCORE_ENVIRONMENT=Production
# SENSORHUB_PATH=../sensorhub    # path to the sensorhub repo if not colocated
# KNOCKKNOCK_PATH=../knock-knock  # path to the knock-knock repo if not colocated

# ── KnockKnock ─────────────────────────────────────────────
KK_DB_PASSWORD=changeme
KK_JWT_SECRET=changeme-min-32-characters-long!!
KK_ADMIN_EMAIL=admin@getknocknock.de
